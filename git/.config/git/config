[status]
	short = true
	branch = true

[commit]
	gpgsign = true
[pull]
	ff = only
[init]
	defaultBranch = main
[core]
	editor = nvim
	pager = delta
[advice]
	forceDeleteBranch = false
	detachedHead = false
[fetch]
	prune = true
	verbose = true

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true

[merge]
    conflictStyle = zdiff3
